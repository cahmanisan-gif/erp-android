<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#F5F7FA">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ Header — white with logo ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp"
                android:elevation="2dp">

                <!-- Logo + greeting row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/logo_rajavapor"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Halo!"
                            android:textColor="#111111"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvCabang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/circle_red"
                        android:backgroundTint="@color/brand_red"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Hero Omzet — white background -->
                <LinearLayout
                    android:id="@+id/layoutOwnerHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Omzet Hari Ini"
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvOmzetHariIni"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rp 0"
                            android:textColor="#111111"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvGrowth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTrxHariIni"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 transaksi"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════ OWNER DASHBOARD ═══════════ -->
            <LinearLayout
                android:id="@+id/layoutOwner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:visibility="gone">

                <!-- ── Period tabs ── -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip7Hari"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Minggu"
                        android:textSize="12sp"
                        android:checked="true"
                        app:chipCornerRadius="16dp"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBulan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Bulan"
                        android:textSize="12sp"
                        app:chipCornerRadius="16dp"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTahun"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Tahun"
                        android:textSize="12sp"
                        app:chipCornerRadius="16dp"
                        app:chipMinHeight="32dp" />
                </com.google.android.material.chip.ChipGroup>

                <!-- ── 3 Charts — horizontal scroll (swipe) ── -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerCharts"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginBottom="12dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:paddingHorizontal="0dp" />

                <!-- Page indicator dots -->
                <LinearLayout
                    android:id="@+id/dotsIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp" />

                <!-- Omzet Bulan — white card prominent -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Omzet Bulan Ini"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvOmzetBulan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="#111111"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:id="@+id/tvTrxBulan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 transaksi"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3 column: Cash | Transfer | Staff -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Cash -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cash" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvCash" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Rp 0"
                                android:textColor="#2E7D32" android:textSize="14sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Transfer -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="5dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Transfer" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvNonCash" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Rp 0"
                                android:textColor="#1565C0" android:textSize="14sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Staff -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Staff Hadir" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvStaffHadir" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0/0"
                                android:textColor="@color/success_green" android:textSize="14sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- 2 column: Retur | Pengeluaran — simetris -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Retur Pending" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvReturPending" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textColor="@color/brand_red" android:textSize="20sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pengeluaran" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvPengeluaran" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Rp 0"
                                android:textColor="#111111" android:textSize="20sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Section: Top Performers -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOP PERFORMERS"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Produk Terlaris" android:textColor="#111111" android:textSize="14sp"
                            android:textStyle="bold" android:layout_marginBottom="10dp" />
                        <TextView android:id="@+id/tvTopProduk" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="-"
                            android:textColor="#666666" android:textSize="13sp" android:lineSpacingExtra="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kasir Terbaik" android:textColor="#111111" android:textSize="14sp"
                            android:textStyle="bold" android:layout_marginBottom="10dp" />
                        <TextView android:id="@+id/tvTopKasir" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="-"
                            android:textColor="#666666" android:textSize="13sp" android:lineSpacingExtra="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cabang Terbaik" android:textColor="#111111" android:textSize="14sp"
                            android:textStyle="bold" android:layout_marginBottom="10dp" />
                        <TextView android:id="@+id/tvTopCabang" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="-"
                            android:textColor="#666666" android:textSize="13sp" android:lineSpacingExtra="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ═══════════ BASIC STATS ═══════════ -->
            <LinearLayout
                android:id="@+id/layoutBasicStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="5dp"
                        app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="14dp" app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="18dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cabang Aktif" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvStatCabang" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textColor="@color/brand_red" android:textSize="34sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="5dp"
                        app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="14dp" app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="18dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Invoice" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvStatInvoice" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textColor="#111111" android:textSize="34sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="5dp"
                        app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="14dp" app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="18dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Customer" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvStatCustomer" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textColor="@color/success_green" android:textSize="34sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="5dp"
                        android:clickable="true" android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="14dp" app:cardElevation="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="18dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Request" android:textColor="#AAAAAA" android:textSize="11sp" />
                            <TextView android:id="@+id/tvStatRequest" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textColor="#E65100" android:textSize="34sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
