<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvLeaderboardSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOP RANKING"
            android:textColor="#60FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.2" />

        <TextView
            android:id="@+id/tvLeaderboardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="KASIR TERBAIK"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

        <!-- Period selector pills -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            android:paddingHorizontal="16dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBulanIni"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bulan Ini"
                    android:textSize="12sp"
                    android:checked="true"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/brand_red"
                    app:chipCornerRadius="20dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip3Bulan"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 Bulan"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#40FFFFFF"
                    app:chipCornerRadius="20dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip6Bulan"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 Bulan"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#40FFFFFF"
                    app:chipCornerRadius="20dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip9Bulan"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9 Bulan"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#40FFFFFF"
                    app:chipCornerRadius="20dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTahunIni"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Of The Year"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#40FFFFFF"
                    app:chipCornerRadius="20dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Leaderboard list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:clipToPadding="false"
        android:layoutAnimation="@anim/layout_animation_fall_down" />

</LinearLayout>
